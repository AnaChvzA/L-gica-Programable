module practica4_tb ();
reg clk;
reg [3:0] SW;
reg [1:0] KEY;
wire [0:6] HEX0;
wire [0:6] HEX1;
wire [0:6] HEX2;
wire [0:6] HEX3;


practica4 DUT (
	.clk(clk),
	.SW(SW),
	.KEY(KEY),
	.HEX0(HEX0),
	.HEX1(HEX1),
	.HEX2(HEX2),
	.HEX3(HEX3)
	

);

initial 
begin
	clk = 0;
	forever #10 clk = ~clk;
end

initial 
begin

clk = 0;
SW = 4'b0000;
KEY = 2'b11;


#100;
	
	KEY[0] = 0;  // Presionar reset
	#50;
	KEY[0] = 1;  // Soltar reset
	#100;

	SW = 4'b0101;  // 5
	#50;
	KEY[1] = 0;    // Presionar CHECK
	#50;
	KEY[1] = 1;    // Soltar CHECK
	#100;
	
	SW = 4'b0010;  // 2
	#50;
	KEY[1] = 0;    // Presionar CHECK
	#50;
	KEY[1] = 1;    // Soltar CHECK
	#100;

	SW = 4'b0011;  // 3
	#50;
	KEY[1] = 0;    // Presionar CHECK
	#50;
	KEY[1] = 1;    // Soltar CHECK
	#100;
	
	SW = 4'b0100;  // 4
	#50;
	KEY[1] = 0;    // Presionar CHECK
	#50;
	KEY[1] = 1;    // Soltar CHECK
	#100;
			
	// Esperar un tiempo en estado GOOD
	#200;
	
	KEY[0] = 0;  // Presionar reset
	#50;
	KEY[0] = 1;  // Soltar reset
	#100;
	
	SW = 4'b0101;  // 5
	#50;
	KEY[1] = 0;
	#50;
	KEY[1] = 1;
	#100;
	
	SW = 4'b0010;  // 2
	#50;
	KEY[1] = 0;
	#50;
	KEY[1] = 1;
	#100;

	SW = 4'b0001;  // 1 (mal)
	#50;
	KEY[1] = 0;
	#50;
	KEY[1] = 1;
	#100;
			
	#200;
	
	$stop;
	$finish;
end

	// Monitor de salidas
	initial
	begin
		$monitor("[%0t ns] SW=%4b | KEY={reset=%b, check=%b} | HEX3=%7b HEX2=%7b HEX1=%7b HEX0=%7b", 
			$time, SW, KEY[0], KEY[1], HEX3, HEX2, HEX1, HEX0);
	end

endmodule
