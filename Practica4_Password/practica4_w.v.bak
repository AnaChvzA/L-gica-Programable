module practica4_w (
	input [1:0] KEY,
	input CLOCK_50,
	input [3:0] SW,
	output[0:6] HEX0,
	output[0:6] HEX1,
	output[0:6] HEX2,
	output[0:6] HEX3

);

practica4 WRAP (
	.clk(CLOCK_50),
	.rst(~KEY[0]),
	.x(SW[3:0]),
	.check(~KEY[1]),
	.HEX0(HEX0),
	.HEX1(HEX1),
	.HEX2(HEX2),
	.HEX3(HEX3)


);

endmodule