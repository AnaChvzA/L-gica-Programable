module BCD_module_tb();
	reg [9:0] bcd_in;
	wire [6:0] D_un, D_de, D_ce, D_mi;
	
//Instanciar el bloque para los 4 displays	
BCD_4displays DUT (
	.D_un(D_un),
	.D_de(D_de),
	.D_ce(D_ce),
	.D_mi(D_mi)
);	

//Pruebas con random

initial

	begin
	$display("Simulación iniciada");
	repeat(15) 
	begin
	
	bcd_in = $random %1024;
	#10;

	end
	
	$stop;
	$finish;
	
	end

initial
	begin
	$monitor("bcd_in = %b, bcd_in = %d0, D_un= %d0, D_de = %d0, D_ce = %d0, D_mi = %d0", bcd_in, bcd_in, D_un, D_de, D_ce, D_mi);
end

endmodule